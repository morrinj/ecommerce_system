RewriteEngine On
RewriteBase /smartshopping/ecommerce_system/

# Route all admin URLs through main index.php (bypass admin/ directory)
RewriteRule ^admin(?:/.*)?$ index.php [QSA,L]

# Redirect to index.php if not a real file/directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Security: block sensitive files
<FilesMatch "\.(sql|env|md|log|json)$">
    Deny from all
</FilesMatch>

# Security: block directory listing
Options -Indexes

# Security: protect config and models
<FilesMatch "^(config|models|controllers)">
    Deny from all
</FilesMatch>
